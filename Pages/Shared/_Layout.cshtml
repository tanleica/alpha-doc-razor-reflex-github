    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const lightTheme = document.getElementById('prism-light-theme');
            const darkTheme = document.getElementById('prism-dark-theme');
            const toggleBtn = document.getElementById('theme-toggle');

            // Load preference from localStorage
            if (localStorage.getItem('prism-theme') === 'dark') {
                darkTheme.removeAttribute('disabled');
                lightTheme.setAttribute('disabled', true);
            }

            toggleBtn.addEventListener('click', () => {
                const isDark = !darkTheme.disabled;
                if (isDark) {
                    darkTheme.setAttribute('disabled', true);
                    lightTheme.removeAttribute('disabled');
                    localStorage.setItem('prism-theme', 'light');
                } else {
                    darkTheme.removeAttribute('disabled');
                    lightTheme.setAttribute('disabled', true);
                    localStorage.setItem('prism-theme', 'dark');
                }
            });
        });
    </script>


    <script>
        document.addEventListener("DOMContentLoaded", function () {
            document.querySelectorAll(".toggle-icon").forEach(el => {
                el.addEventListener("pointerdown", function () {
                    const childId = el.dataset.target;
                    const iconId = el.dataset.icon;
                    toggleChildren(childId, iconId);
                });
            });
        });

        function toggleChildren(childId, iconId) {
            const children = document.getElementById(childId);
            const icon = document.getElementById(iconId);
            if (children.style.display === "none") {
                children.style.display = "block";
                icon.textContent = "▼";
            } else {
                children.style.display = "none";
                icon.textContent = "▶";
            }
        }
    </script>

    <!-- Bootstrap 5 bundle (includes Popper). Only include once -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
        crossorigin="anonymous"></script>

    <!-- data for d3 -->
    <script src="~/js/d3.js"></script>

    <!-- data for d3 -->
    <script src="~/js/vietmap.js"></script>
    <script src="~/js/uamap.js"></script>

    <script>
    (function () {
    const setDocHeight = () => {
        const vh = window.visualViewport ? window.visualViewport.height : window.innerHeight;
        document.documentElement.style.setProperty('--doc-height', vh + 'px');
    };

    setDocHeight();
    window.visualViewport && window.visualViewport.addEventListener('resize', setDocHeight);
    window.addEventListener('resize', setDocHeight);
    window.addEventListener('orientationchange', setDocHeight);
    })();
    </script>

    <script src="https://unpkg.com/feather-icons@4.29.2/dist/feather.min.js"></script>
    <script>
    document.addEventListener("DOMContentLoaded", () => {
        feather.replace();
    });
    </script>

    @RenderSection("Scripts", required: false)
</body>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const toggleBtn = document.getElementById("theme-toggle");
        const html = document.documentElement;
        const prismLight = document.getElementById("prism-light-theme");
        const prismDark = document.getElementById("prism-dark-theme");
        const body = document.body;

        function applyTheme(theme) {
            const isDark = theme === "dark";

            // Smooth transition class
            body.classList.add("theme-transition");
            setTimeout(() => body.classList.remove("theme-transition"), 300);

            html.setAttribute("data-bs-theme", theme);
            localStorage.setItem("site-theme", theme);

            if (isDark) {
                prismDark.disabled = false;
                prismLight.disabled = true;
                toggleBtn.innerText = "☀️";
            } else {
                prismDark.disabled = true;
                prismLight.disabled = false;
                toggleBtn.innerText = "🌙";
            }
        }

        // Init
        applyTheme(localStorage.getItem("site-theme") || "light");

        // Toggle on click
        toggleBtn.addEventListener("click", () => {
            const next = html.getAttribute("data-bs-theme") === "dark" ? "light" : "dark";
            applyTheme(next);
        });
    });
</script>

</html>

