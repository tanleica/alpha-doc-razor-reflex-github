@using MiukaFotoRazor
@using Microsoft.AspNetCore.Http
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    var isLoggedIn = HttpContextAccessor.HttpContext?.Session.GetString("UserId") != null;
    var isRoot = HttpContextAccessor.HttpContext?.Session.GetString("IsRoot") == "True";
}

<!DOCTYPE html>
<html lang="en" data-bs-theme="light"> <!-- Default to light -->

<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - AlphaDoc</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    @RenderSection("Head", required: false)

    <!-- Instant theme application -->
    <script>
        (function () {
            const saved = localStorage.getItem("site-theme") || "light";
            const html = document.documentElement;
            html.setAttribute("data-bs-theme", saved);

            // Prism
            const head = document.head;
            const prismLight = document.createElement("link");
            prismLight.id = "prism-light-theme";
            prismLight.rel = "stylesheet";
            prismLight.href = "https://cdn.jsdelivr.net/npm/prismjs@1.29.0/themes/prism.min.css";
            if (saved === "dark") prismLight.disabled = true;

            const prismDark = document.createElement("link");
            prismDark.id = "prism-dark-theme";
            prismDark.rel = "stylesheet";
            prismDark.href = "https://cdn.jsdelivr.net/npm/prismjs@1.29.0/themes/prism-tomorrow.min.css";
            if (saved !== "dark") prismDark.disabled = true;

            head.appendChild(prismLight);
            head.appendChild(prismDark);

        // ✅ Pre-set toggle button text BEFORE paint
        document.addEventListener("DOMContentLoaded", () => {
            const btn = document.getElementById("theme-toggle");
            if (btn) {
                btn.innerText = saved === "dark" ? "☀️" : "🌙";
            }
        });

        })();
    </script>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/prism.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/ms.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/article.css" asp-append-version="true" />
    <link href="https://fonts.cdnfonts.com/css/open-sans" rel="stylesheet">

    <style>
        :root { --doc-height: 100vh; }

        html, body { height: 100%; margin: 0; }

        /* Flex layout with a sticky footer */
        body {
            display: flex;
            flex-direction: column;
            min-height: 100dvh;            /* modern */
            min-height: var(--doc-height); /* fallback */
        }

        main { flex: 1; min-height: 0; }

        /* Footer sits flush to the bottom and respects safe area */
        footer {
            margin-top: auto;
            padding: 12px 16px calc(12px + env(safe-area-inset-bottom));
        }

        /* Kill “mystery” bottom space from Bootstrap/utility margins */
        main > *:last-child { margin-bottom: 0 !important; }
    </style>

</head>

<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-page="/Index">AlphaDoc</a>

                <!-- Mobile toggle button for category menu -->
                <button class="btn btn-outline-secondary d-md-none me-2" type="button" data-bs-toggle="offcanvas"
                    data-bs-target="#offcanvasCategoryTree" aria-controls="offcanvasCategoryTree">
                    ☰ Topics
                </button>

                <!-- Main menu toggle -->
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarCollapse"
                    aria-controls="navbarCollapse" aria-expanded="false" aria-label="Toggle navigation">
                    ☰
                </button>

                <!-- Theme toggle -->
                <button id="theme-toggle" class="btn btn-outline-secondary">🌓</button>

                <div class="collapse navbar-collapse" id="navbarCollapse">
                    <!-- Left nav items -->
                    <ul class="navbar-nav me-auto mb-2 mb-sm-0">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-page="/Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-page="/Privacy">Privacy</a>
                        </li>
                        @if (isRoot)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-page="/Auth/Login">Root Page</a>
                            </li>
                        }
                    </ul>

                    <!-- Right auth items -->
                    <ul class="navbar-nav ms-auto mt-3 mt-sm-0 order-last order-sm-last px-2">
                        @if (!isLoggedIn)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark px-3" asp-page="/Auth/Login">Login</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <form method="post" asp-page="/Auth/Logout" class="d-inline m-0 p-0">
                                    <button type="submit"
                                        class="nav-link btn btn-link p-0 m-0 px-3 text-dark bg-transparent border-0 align-baseline">
                                        Logout
                                    </button>
                                </form>
                            </li>
                        }
                    </ul>

                </div>
            </div>
        </nav>

    </header>

    <!-- Responsive layout -->
    <div class="container-fluid">
        <div class="row">
            <!-- Desktop Sidebar -->
            <aside class="col-md-3 d-none d-md-block">
                @await Component.InvokeAsync("CategoryTreeMenu")
            </aside>

            <!-- Main content -->
            <main class="col-md-9">
                @RenderBody()
            </main>
        </div>
    </div>

    <!-- Offcanvas for mobile -->
    <div class="offcanvas offcanvas-start d-md-none" tabindex="-1" id="offcanvasCategoryTree"
        aria-labelledby="offcanvasCategoryTreeLabel">
        <div class="offcanvas-header">
            <h5 class="offcanvas-title" id="offcanvasCategoryTreeLabel">Topics</h5>
            <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
        </div>
        <div class="offcanvas-body">
            @await Component.InvokeAsync("CategoryTreeMenu")
        </div>
    </div>


    <footer class="border-top footer text-muted mt-5">
        <div class="container">
            &copy; @DateTime.Now.Year - AlphaDoc
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <!-- PrismJS core -->
    <script src="~/js/prism.js"></script>

    <!-- Clipboard.js -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/clipboard.js/2.0.11/clipboard.min.js"></script>

